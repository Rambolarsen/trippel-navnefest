---
import BaseLayout from "../layouts/BaseLayout.astro";
import { gifts } from "../data/gifts";
import { hasValidAdminSession } from "../lib/auth";
import { getDb } from "../lib/database";
import { hasActiveInvitationToken } from "../lib/invitations";
import { countReservationsByGift } from "../lib/reservations";

const isAdmin = await hasValidAdminSession(Astro.cookies);
const errorKind = Astro.url.searchParams.get("feil");
const errorMessage =
  errorKind === "mange"
    ? "For mange forsøk. Vent et minutt og prøv igjen."
    : errorKind
      ? "Det passordet stemte ikke. Prøv gjerne igjen."
      : null;

// Kun tall vises – aldri hvem som har reservert (MVP.md §6).
let rows: { id: string; title: string; mode: string; count: number }[] = [];
let hasInvitationToken = false;
if (isAdmin) {
  const counts = await countReservationsByGift(getDb());
  hasInvitationToken = await hasActiveInvitationToken(getDb());
  rows = gifts.map((gift) => ({
    id: gift.id,
    title: gift.title,
    mode: gift.mode === "group" ? "Spleis" : "Enkeltgave",
    count: counts.get(gift.id) ?? 0,
  }));
}
---

<BaseLayout title="Admin – navnefest">
  <main>
    <h1>Admin</h1>
    {
      !isAdmin ? (
        <>
          <p class="muted">Skriv inn admin-passordet for å administrere ønskelisten.</p>
          <form method="post" action="/api/admin/login">
            <label for="passphrase">Admin-passord</label>
            <input
              type="password"
              id="passphrase"
              name="passphrase"
              required
              autocomplete="current-password"
            />
            {errorMessage && (
              <p class="error" role="alert">
                {errorMessage}
              </p>
            )}
            <button type="submit">Logg inn</button>
          </form>
        </>
      ) : (
        <>
          <p class="muted">
            Antall reservasjoner og spleiseinteresser per gave. Hvem som har
            reservert, lagres ikke og kan ikke vises.
          </p>
          <section class="invitation" aria-labelledby="invitation-heading">
            <h2 id="invitation-heading">Invitasjonslenke</h2>
            <p class="muted">
              {hasInvitationToken
                ? "En invitasjonslenke er aktiv. Når du lager en ny, kan den gamle ikke lenger brukes til å logge inn."
                : "Lag en lenke som gir gjester tilgang uten å skrive inn passord."}
            </p>
            {hasInvitationToken && (
              <p class="muted">
                Gjester som allerede er innlogget, beholder sesjonen sin i opptil 30 dager.
              </p>
            )}
            <button type="button" id="create-invitation">
              {hasInvitationToken ? "Lag ny invitasjonslenke" : "Lag invitasjonslenke"}
            </button>
            <div id="invitation-result" hidden>
              <p class="success">Kopier lenken nå. Den vises ikke igjen av sikkerhetshensyn.</p>
              <input id="invitation-url" type="text" readonly aria-label="Invitasjonslenke" />
              <button type="button" class="btn-secondary" id="copy-invitation">Kopier lenke</button>
            </div>
            <p id="invitation-error" class="error" role="alert" hidden></p>
          </section>
          <ul class="admin-list" role="list">
            {rows.map((row) => (
              <li class="admin-row">
                <div>
                  <strong>{row.title}</strong>
                  <p class="muted admin-meta">
                    {row.mode} ·{" "}
                    <span data-count-for={row.id}>
                      {row.count === 1
                        ? "1 reservasjon"
                        : `${row.count} reservasjoner`}
                    </span>
                  </p>
                </div>
                <button
                  type="button"
                  class="btn-secondary"
                  data-reset-gift={row.id}
                  data-gift-title={row.title}
                  disabled={row.count === 0}
                >
                  Nullstill
                </button>
              </li>
            ))}
          </ul>
        </>
      )
    }
  </main>
</BaseLayout>

<style>
  form {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-block-start: 1rem;
  }

  input {
    max-width: 22rem;
  }

  .error {
    margin: 0;
    color: #9b2c13;
    font-weight: 600;
  }

  .admin-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .invitation {
    margin-block: 1.5rem;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .invitation h2 {
    margin-top: 0;
  }

  #invitation-result {
    display: grid;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  #invitation-url {
    max-width: none;
  }

  .success {
    margin: 0;
    color: #256d3d;
    font-weight: 600;
  }

  .admin-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .admin-meta {
    margin: 0.125rem 0 0;
    font-size: 0.9rem;
  }
</style>

<script>
  const createInvitationButton = document.querySelector<HTMLButtonElement>(
    "#create-invitation",
  );
  const invitationResult = document.querySelector<HTMLElement>("#invitation-result");
  const invitationUrl = document.querySelector<HTMLInputElement>("#invitation-url");
  const copyInvitationButton = document.querySelector<HTMLButtonElement>("#copy-invitation");
  const invitationError = document.querySelector<HTMLElement>("#invitation-error");

  createInvitationButton?.addEventListener("click", async () => {
    if (!confirm("Lage en ny invitasjonslenke? En eventuell tidligere lenke kan ikke brukes til å logge inn etterpå.")) {
      return;
    }

    createInvitationButton.disabled = true;
    invitationError!.hidden = true;
    try {
      const response = await fetch("/api/admin/invitation", { method: "POST" });
      if (!response.ok) throw new Error(String(response.status));
      const body = (await response.json()) as { invitationUrl: string };
      invitationUrl!.value = body.invitationUrl;
      invitationResult!.hidden = false;
      createInvitationButton.textContent = "Lag ny invitasjonslenke";
      invitationUrl!.select();
    } catch {
      invitationError!.textContent = "Kunne ikke lage invitasjonslenken. Prøv igjen.";
      invitationError!.hidden = false;
    } finally {
      createInvitationButton.disabled = false;
    }
  });

  copyInvitationButton?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(invitationUrl!.value);
      copyInvitationButton.textContent = "Kopiert";
    } catch {
      invitationUrl!.select();
      document.execCommand("copy");
      copyInvitationButton.textContent = "Kopiert";
    }
  });

  // Nullstilling via DELETE-endepunktet (MVP.md §12), med bekreftelse.
  document.addEventListener("click", async (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>(
      "[data-reset-gift]",
    );
    if (!button) return;

    const giftId = button.dataset.resetGift!;
    const title = button.dataset.giftTitle ?? giftId;
    if (!confirm(`Fjerne alle reservasjoner på «${title}»?`)) return;

    button.disabled = true;
    try {
      const response = await fetch(`/api/admin/gifts/${giftId}/reservations`, {
        method: "DELETE",
      });
      if (!response.ok) throw new Error(String(response.status));
      const counter = document.querySelector(`[data-count-for="${giftId}"]`);
      if (counter) counter.textContent = "0 reservasjoner";
    } catch {
      alert("Nullstillingen feilet. Prøv igjen.");
      button.disabled = false;
    }
  });
</script>
