---
import BaseLayout from "../layouts/BaseLayout.astro";
import GiftCard from "../components/GiftCard.astro";
import GiftFilters from "../components/GiftFilters.tsx";
import NameForm from "../components/NameForm.tsx";
import ReservationRecovery from "../components/ReservationRecovery.tsx";
import { getCurrentRecoveryCode } from "../lib/reservations";
import { gifts } from "../data/gifts";

// Sorter høyt prioriterte gaver først
const sortedGifts = [...gifts].sort(
  (a, b) => (b.priority === "high" ? 1 : 0) - (a.priority === "high" ? 1 : 0),
);
const recoveryCode = await getCurrentRecoveryCode(Astro.cookies);
---

<BaseLayout title="Ønskeliste – navnefest for Edvin, Jonas og Sofie">
  <main>
    <h1>Ønskeliste</h1>
    <p class="muted">
      Flere har spurt hva barna ønsker seg til navnefesten. Gaver er selvfølgelig
      ikke nødvendig, men her er noen forslag dersom du ønsker å gi noe.
    </p>

    {/* client:only: navnet leses fra localStorage og finnes ikke ved SSR */}
    <NameForm client:only="react" />
    <ReservationRecovery client:load initialRecoveryCode={recoveryCode} />

    <GiftFilters client:load />

    <div class="gift-list">
      {sortedGifts.map((gift) => <GiftCard gift={gift} />)}
    </div>
  </main>
</BaseLayout>

<style>
  .gift-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-block-start: 1rem;
  }

  @media (min-width: 40rem) {
    .gift-list {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<style is:global>
  /* Stiler for GiftFilters-øya (React-komponenter kan ikke bruke
     Astro-scoped CSS, så de deles her via layoutens tokens). */
  .gift-filters {
    margin-block-start: 0.5rem;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-btn {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-weight: 500;
  }

  .filter-btn:hover {
    background: rgba(61, 46, 29, 0.06);
  }

  .filter-btn.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
    font-weight: 600;
  }

  .filter-btn.is-active:hover {
    background: var(--color-primary-strong);
  }

  .filter-status {
    min-height: 1.5rem;
    margin-block: 0.5rem 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  /* Stiler for NameForm-øya (MVP.md §8) */
  .name-form {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-block: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .name-form label {
    font-weight: 600;
  }

  .name-form-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .name-form-row input {
    flex: 1 1 12rem;
    max-width: 22rem;
  }

  .name-form-status {
    margin: 0;
    font-size: 0.9rem;
  }

  .reservation-recovery {
    margin-block: 1rem;
  }

  .reservation-recovery-code {
    padding: 0.75rem 1rem;
    background: #fff7d6;
    border: 1px solid #c88a00;
    border-radius: var(--radius);
  }

  .reservation-recovery-code p {
    margin: 0.25rem 0;
  }

  .reservation-recovery-code code {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .reservation-recovery-code-value {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin: 0.25rem 0;
  }

  .reservation-recovery-copy {
    display: inline-grid;
    width: 2rem;
    height: 2rem;
    padding: 0;
    place-items: center;
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
  }

  .reservation-recovery-copy:hover {
    background: rgba(61, 46, 29, 0.06);
  }

  .reservation-recovery-copy svg {
    width: 1.125rem;
    height: 1.125rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .reservation-recovery-copy-error {
    color: #9b2c13;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .reservation-recovery summary {
    cursor: pointer;
    color: var(--color-text-muted);
  }

  .reservation-recovery form {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-block-start: 0.75rem;
  }

  .reservation-recovery-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    width: 100%;
  }

  .reservation-recovery input {
    flex: 1 1 12rem;
    max-width: 22rem;
    min-width: 0;
  }

  .reservation-recovery-message {
    margin: 0;
  }
</style>
