---
import BaseLayout from "../layouts/BaseLayout.astro";

const errorKind = Astro.url.searchParams.get("feil");
const errorMessage =
  errorKind === "mange"
    ? "For mange forsøk. Vent et minutt og prøv igjen."
    : errorKind
      ? "Det passordet stemte ikke. Prøv gjerne igjen."
      : null;
---

<BaseLayout title="Navnefest – ønskeliste">
  <main>
    <h1>Navnefest for Edvin, Jonas og Sofie</h1>
    <p class="muted">
      Skriv inn passordet fra invitasjonen for å åpne ønskelisten.
    </p>

    <form method="post" action="/api/login">
      <label for="passphrase">Passord</label>
      <input
        type="password"
        id="passphrase"
        name="passphrase"
        required
        autocomplete="current-password"
        autofocus={errorMessage !== null}
      />
      {
        errorMessage && (
          <p class="error" role="alert">
            {errorMessage}
          </p>
        )
      }
      <button type="submit">Åpne ønskelisten</button>
    </form>
  </main>
</BaseLayout>

<style>
  form {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-block-start: 1rem;
  }

  input {
    max-width: 22rem;
  }

  .error {
    margin: 0;
    color: #9b2c13;
    font-weight: 600;
  }
</style>
