---
import type { Gift } from "../data/gifts";
import GiftReservationButton from "./GiftReservationButton.tsx";
import Tag from "./Tag.astro";

type Props = {
  gift: Gift;
};

const { gift } = Astro.props;
---

<article
  class="gift-card"
  data-gift-card
  data-gift-id={gift.id}
  data-mode={gift.mode}
  data-status="available"
  data-tags={gift.tags.join("|")}
>
  {
    gift.image ? (
      <img class="gift-image" src={gift.image} alt={gift.title} loading="lazy" />
    ) : (
      <div class="gift-image gift-image-placeholder" aria-hidden="true">🎁</div>
    )
  }
  <div class="gift-body">
    <h2 class="gift-title">{gift.title}</h2>
    <p class="gift-description">{gift.description}</p>
    <ul class="gift-tags" role="list">
      {gift.tags.map((tag) => (
        <li>
          <Tag label={tag} />
        </li>
      ))}
    </ul>
    {gift.priceLabel && <p class="gift-price muted">{gift.priceLabel}</p>}
    {
      gift.link && (
        <a class="gift-link" href={gift.link} target="_blank" rel="noopener noreferrer">
          Se gave ↗
        </a>
      )
    }
    <GiftReservationButton client:load giftId={gift.id} mode={gift.mode} />
  </div>
</article>

<style>
  .gift-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .gift-image {
    width: 100%;
    height: 9rem;
    margin-block-start: 0.75rem;
    display: block;
    object-fit: contain;
    background: #fff;
    flex: none;
  }

  .gift-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    background: linear-gradient(135deg, #f6e8d8, #efe0ea);
  }

  .gift-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 1rem;
  }

  .gift-title {
    font-size: 1.2rem;
    margin: 0;
  }

  .gift-description {
    margin: 0;
  }

  .gift-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
  }

  .gift-price {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
  }

  .gift-link {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: var(--color-accent);
  }
</style>

<style is:global>
  /* Stiler for GiftReservationButton-øya (React-elementer får ikke
     Astro-scoped attributter, så disse må være globale). */
  .reservation {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    margin-block-start: 0.25rem;
  }

  .reservation-status p {
    margin: 0.25rem 0;
    font-weight: 600;
  }

  .reservation-error {
    color: #9b2c13;
  }

  .reservation-recovery-code {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-block: 0.5rem;
    padding: 0.75rem;
    background: #fff7d6;
    border: 1px solid #c88a00;
    border-radius: var(--radius);
  }

  .reservation-recovery-code code {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  /* Spleisedetaljer (MVP.md §8): deltakerliste og navneskjema */
  .reservation-status .reservation-participants {
    font-weight: 400;
  }

  .reservation-hint {
    margin: 0;
    font-size: 0.85rem;
  }

  .reservation-name-form {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    width: 100%;
  }

  .reservation-name-form label {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .reservation-name-form input {
    max-width: 18rem;
  }

  .reservation-name-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
