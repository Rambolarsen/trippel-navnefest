---
import type { Gift } from "../data/gifts";
import Tag from "./Tag.astro";

type Props = {
  gift: Gift;
};

const { gift } = Astro.props;

// Reservasjonsstatus kobles til API-et i fase 3-4 (issue #5-#7).
// Inntil da vises alle gaver som ledige.
const statusText = "Ledig";
const buttonLabel =
  gift.mode === "group" ? "Jeg vil være med og spleise" : "Jeg tenker å kjøpe denne";
---

<article
  class="gift-card"
  data-gift-card
  data-gift-id={gift.id}
  data-mode={gift.mode}
  data-status="available"
  data-tags={gift.tags.join("|")}
>
  {
    gift.image ? (
      <img class="gift-image" src={gift.image} alt={gift.title} loading="lazy" />
    ) : (
      <div class="gift-image gift-image-placeholder" aria-hidden="true">🎁</div>
    )
  }
  <div class="gift-body">
    <h2 class="gift-title">{gift.title}</h2>
    <p class="gift-description">{gift.description}</p>
    <ul class="gift-tags" role="list">
      {gift.tags.map((tag) => (
        <li>
          <Tag label={tag} />
        </li>
      ))}
    </ul>
    {gift.priceLabel && <p class="gift-price muted">{gift.priceLabel}</p>}
    <p class="gift-status" data-status-text>
      {statusText}
    </p>
    <button type="button" disabled>
      {buttonLabel}
    </button>
  </div>
</article>

<style>
  .gift-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .gift-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .gift-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    background: linear-gradient(135deg, #f6e8d8, #efe0ea);
  }

  .gift-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 1rem;
  }

  .gift-title {
    font-size: 1.2rem;
    margin: 0;
  }

  .gift-description {
    margin: 0;
  }

  .gift-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
  }

  .gift-price {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
  }

  .gift-status {
    margin: 0.25rem 0;
    font-weight: 600;
  }
</style>
