---
type Props = {
  label: string;
};

const { label } = Astro.props;
---

<span class="tag">{label}</span>

<style>
  .tag {
    display: inline-block;
    padding: 0.125rem 0.625rem;
    border-radius: 999px;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
  }
</style>
