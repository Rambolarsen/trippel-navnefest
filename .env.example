# Kopier denne filen til .env og fyll inn verdier lokalt.
# I produksjon settes disse som Cloudflare-miljøvariabler.
# Ingen faktiske verdier skal sjekkes inn i repoet (MVP.md §14).

# Felles passphrase gjestene får i invitasjonen
GUEST_PASSPHRASE=

# Separat passphrase for adminsiden
ADMIN_PASSPHRASE=

# Hemmelighet for signering av sesjonscookies
SESSION_SECRET=

# Hemmelighet for signering av reservasjonstoken-cookien
RESERVATION_SECRET=
